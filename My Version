<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Composition Tool</title>
  <style>
    body { margin: 0; background: #1a1a1a; height: 100vh; overflow: hidden; cursor: crosshair; }
    /* The selection rectangle shown while dragging */
    #selection {
      position: absolute;
      border: 1px dashed #fff;
      background: rgba(255,255,255,0.08);
      pointer-events: none;
      display: none;
    }
    /* The actual canvas, placed where you dragged */
    #c {
      position: absolute;
      background: #333;
      border: 1px solid #555;
      display: none;
    }
  </style>
</head>
<body>
  <div id="selection"></div>
  <canvas id="c"></canvas>

  <script>
    const selection = document.getElementById("selection");
    const canvas = document.getElementById("c");
    const ctx = canvas.getContext("2d");

    let startX = 0;
    let startY = 0;
    let isDragging = false;

    // 1. Press mouse down → record where we started
    document.addEventListener("mousedown", (e) => {
      isDragging = true;
      startX = e.clientX;
      startY = e.clientY;

      selection.style.display = "block";
      selection.style.left = startX + "px";
      selection.style.top = startY + "px";
      selection.style.width = "0px";
      selection.style.height = "0px";
    });

    // 2. Move mouse while held → resize the dashed preview rectangle
    document.addEventListener("mousemove", (e) => {
      if (!isDragging) return;

      // Math.min handles dragging in any direction (up-left, down-right, etc.)
      const x = Math.min(e.clientX, startX);
      const y = Math.min(e.clientY, startY);
      const width = Math.abs(e.clientX - startX);
      const height = Math.abs(e.clientY - startY);

      selection.style.left = x + "px";
      selection.style.top = y + "px";
      selection.style.width = width + "px";
      selection.style.height = height + "px";
    });

    // 3. Release mouse → build the real canvas at that size/position
    document.addEventListener("mouseup", (e) => {
      if (!isDragging) return;
      isDragging = false;
      selection.style.display = "none";

      const x = Math.min(e.clientX, startX);
      const y = Math.min(e.clientY, startY);
      const width = Math.abs(e.clientX - startX);
      const height = Math.abs(e.clientY - startY);

      // Ignore tiny accidental clicks
      if (width < 10 || height < 10) return;

      // Position and size the canvas
      canvas.style.display = "block";
      canvas.style.left = x + "px";
      canvas.style.top = y + "px";
      canvas.width = width;
      canvas.height = height;

      drawGrid(width, height);
    });

    // Draw the rule-of-thirds grid, scaled to the canvas size
    function drawGrid(w, h) {
      ctx.clearRect(0, 0, w, h);
      ctx.strokeStyle = "rgba(255,255,255,0.6)";
      ctx.lineWidth = 1;
      ctx.beginPath();

      ctx.moveTo(w / 3, 0);
      ctx.lineTo(w / 3, h);
      ctx.moveTo((w / 3) * 2, 0);
      ctx.lineTo((w / 3) * 2, h);

      ctx.moveTo(0, h / 3);
      ctx.lineTo(w, h / 3);
      ctx.moveTo(0, (h / 3) * 2);
      ctx.lineTo(w, (h / 3) * 2);

      ctx.stroke();
    }
  </script>
</body>
</html>