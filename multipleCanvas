<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Composition Tool</title>
  <style>
    body {
      margin: 0;
      height: 100vh;
      background: #1a1a1a;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    /* The square container */
    .app {
      position: relative;
      width: 500px;
      height: 500px;
      background: #2a2a2a;
      border: 1px solid #555;
    }

    /* The button column on the side */
    .sidebar {
      position: absolute;
      top: 0;
      left: -60px;          /* sits just outside the square's left edge */
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .sidebar button {
      width: 50px;
      height: 50px;
      background: #444;
      color: #fff;
      border: 1px solid #666;
      cursor: pointer;
      font-size: 16px;
    }

    .sidebar button:hover { background: #555; }
    .sidebar button.active { background: #0a84ff; }  /* highlight current page */

    /* Each canvas fills the square. Hidden by default. */
    .page {
      position: absolute;
      top: 0;
      left: 0;
      display: none;
    }

    .page.visible { display: block; }
  </style>
</head>
<body>
  <div class="app">
    <div class="sidebar">
      <button data-page="0" class="active">1</button>
      <button data-page="1">2</button>
      <button data-page="2">3</button>
    </div>

    <canvas class="page visible" width="500" height="500"></canvas>
    <canvas class="page" width="500" height="500"></canvas>
    <canvas class="page" width="500" height="500"></canvas>
  </div>

  <script>
    const buttons = document.querySelectorAll(".sidebar button");
    const pages = document.querySelectorAll(".page");

    // Switch pages when a button is clicked
    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const index = Number(button.dataset.page);

        // Hide all pages, show the chosen one
        pages.forEach((page) => page.classList.remove("visible"));
        pages[index].classList.add("visible");

        // Update which button looks "active"
        buttons.forEach((b) => b.classList.remove("active"));
        button.classList.add("active");
      });
    });

    // Draw something different on each canvas so you can tell them apart
    drawPage1(pages[0].getContext("2d"));
    drawPage2(pages[1].getContext("2d"));
    drawPage3(pages[2].getContext("2d"));

    function drawPage1(ctx) {
      ctx.fillStyle = "#e74c3c";
      ctx.fillRect(50, 50, 400, 400);
      label(ctx, "Page 1");
    }

    function drawPage2(ctx) {
      ctx.fillStyle = "#2ecc71";
      ctx.beginPath();
      ctx.arc(250, 250, 200, 0, Math.PI * 2);
      ctx.fill();
      label(ctx, "Page 2");
    }

    function drawPage3(ctx) {
      ctx.strokeStyle = "#3498db";
      ctx.lineWidth = 4;
      ctx.strokeRect(50, 50, 400, 400);
      label(ctx, "Page 3");
    }

    function label(ctx, text) {
      ctx.fillStyle = "#fff";
      ctx.font = "24px sans-serif";
      ctx.fillText(text, 20, 40);
    }
  </script>
</body>
</html>